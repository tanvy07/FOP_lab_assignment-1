#include <stdio.h>

int main() {
    int num, remainder;

    printf("Enter a number: ");
    scanf("%d", &num);

    printf("Reversed number: ");

    while (num != 0) {
        remainder = num % 10;   // get last digit
        printf("%d", remainder); // print it
        num = num / 10;         // remove last digit
    }

    return 0;
}
