#include <stdio.h>

void swapByValue(int a, int b);
void swapByReference(int *a, int *b);

int main() {
    int num1, num2;

    printf("Enter two integers: ");
    scanf("%d %d", &num1, &num2);

    printf("\n Call by Value\n");
    printf("Before: num1 = %d, num2 = %d\n", num1, num2);
    swapByValue(num1, num2);
    printf("After:  num1 = %d, num2 = %d (No change)\n", num1, num2);

    printf("\nCall by Reference \n");
    printf("Before: num1 = %d, num2 = %d\n", num1, num2);
    swapByReference(&num1, &num2);
    printf("After:  num1 = %d, num2 = %d (Swapped)\n", num1, num2);

    return 0;
}

void swapByValue(int a, int b) {
    int temp = a;
    a = b;
    b = temp;
}

void swapByReference(int *a, int *b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}
