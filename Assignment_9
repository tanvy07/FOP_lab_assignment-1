#include <stdio.h>

int main() {
    int num, original, remainder, result = 0;

    printf("Enter a three-digit number: ");
    scanf("%d", &num);

    original = num;

    while (num != 0) {
        remainder = num % 10;
        result += remainder * remainder * remainder;
        num /= 10;
    }

    if (result == original)
        printf("Armstrong number");
    else
        printf("Not an Armstrong number");

    return 0;
}
