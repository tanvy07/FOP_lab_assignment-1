#include <stdio.h>

void addition() {
    int a[10][10], b[10][10], sum[10][10];
    int r, c, i, j;

    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &c);

    printf("Enter Matrix A:\n");
    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            scanf("%d",&a[i][j]);

    printf("Enter Matrix B:\n");
    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            scanf("%d",&b[i][j]);

    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            sum[i][j] = a[i][j] + b[i][j];

    printf("Result:\n");
    for(i=0;i<r;i++){
        for(j=0;j<c;j++)
            printf("%d ", sum[i][j]);
        printf("\n");
    }
}

void saddle() {
    int a[10][10], r, c, i, j, k, min, col;

    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &c);

    printf("Enter matrix:\n");
    for(i=0;i<r;i++)
        for(j=0;j<c;j++)
            scanf("%d",&a[i][j]);

    for(i=0;i<r;i++){
        min = a[i][0]; col = 0;

        for(j=1;j<c;j++){
            if(a[i][j] < min){
                min = a[i][j];
                col = j;
            }
        }

        for(k=0;k<r;k++){
            if(a[k][col] > min)
                break;
        }

        if(k==r){
            printf("Saddle Point = %d\n", min);
            return;
        }
    }
    printf("No Saddle Point\n");
}

void inverse() {
    float a[2][2], det;

    printf("Enter 2x2 matrix:\n");
    scanf("%f %f %f %f",&a[0][0],&a[0][1],&a[1][0],&a[1][1]);

    det = a[0][0]*a[1][1] - a[0][1]*a[1][0];

    if(det == 0){
        printf("Inverse not possible\n");
        return;
    }

    printf("Inverse matrix:\n");
    printf("%f %f\n", a[1][1]/det, -a[0][1]/det);
    printf("%f %f\n", -a[1][0]/det, a[0][0]/det);
}

void magic() {
    int a[10][10], n, i, j, sum=0, temp;

    printf("Enter order: ");
    scanf("%d",&n);

    printf("Enter matrix:\n");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&a[i][j]);

    for(j=0;j<n;j++)
        sum += a[0][j];

    for(i=1;i<n;i++){
        temp = 0;
        for(j=0;j<n;j++)
            temp += a[i][j];

        if(temp != sum){
            printf("Not Magic Square\n");
            return;
        }
    }
    printf("Magic Square\n");
}

int main() {
    int choice;

    printf("\n1.Addition\n2.Saddle Point\n3.Inverse\n4.Magic Square\n");
    printf("Enter choice: ");
    scanf("%d",&choice);

    switch(choice){
        case 1: addition(); break;
        case 2: saddle(); break;
        case 3: inverse(); break;
        case 4: magic(); break;
        default: printf("Invalid choice");
    }

    return 0;
}
